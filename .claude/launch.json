{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "investor-portal",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": ["run", "app.py", "--server.port", "8501"],
      "port": 8501,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "venv/bin/uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--app-dir", "backend"],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    }
  ]
}
